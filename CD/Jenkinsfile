pipeline {
    agent any

    environment {
        DOCKERHUB_CREDS=credentials('devops-laba1')
        LC_ALL = "en_US.UTF-8"
        LANG    = "en_US.UTF-8"
        LANGUAGE = "en_US.UTF-8"
    }

options {
        timestamps()
        skipDefaultCheckout(true)
	}
    stages {

        stage('Login'){
            steps{
                //withCredentials([usernamePassword(credentialsId: 'devops-laba1', passwordVariable: 'DOCKER_REGISTRY_PWD', usernameVariable: 'DOCKER_REGISTRY_USER')]){
                //bat 'chcp 65001 && echo %DOCKER_REGISTRY_PWD% | docker login -u %DOCKER_REGISTRY_USER% --password-stdin'}
                //bat 'chcp 65001 && echo %DOCKERHUB_CREDS_PSW% | docker login -u %DOCKERHUB_CREDS_USR% --password-stdin'
                bat 'docker login -u %DOCKERHUB_CREDS_USR% -p %DOCKERHUB_CREDS_PSW%'
                }
            }

        stage('Pull image'){
            steps{
                bat '''
                        docker pull nikita123orange/devops-laba1:latest
                '''
            }
        }

        stage('Run container'){
            steps{
                bat '''
                        docker run --name devops-laba1 -p 80:5556 -d nikita123orange/devops-laba1:latest
                '''
            }
        }
	}

    post {
        always {
            node('windows') {
                bat 'docker stop devops-laba1 && docker logout'
            }
        }
    }
}
